# Copy this file to `.env` locally if you need to override defaults.
# Most platforms (Fly.io, Render, Railway, Vercel) read env vars from their
# own dashboards — see DEPLOY.md.

# ---- Server (@red10/server) ----
# PORT=3001
# HOST=0.0.0.0
# CORS_ORIGIN=http://localhost:5173
# SERVE_CLIENT=true

# ---- Client (@red10/client) ----
# VITE_API_URL=https://red10-api.fly.dev

# ---- Bot review pipeline (optional) ----
# When all three are set, the server pushes each finished game's log + a
# structured JSON sidecar to a private repo. Leave unset for no-op.
# Token must be a fine-grained PAT with contents:read/write scoped to
# $LOGS_REPO only. See .plans/review-pipeline.md.
# GITHUB_TOKEN=ghp_...
# LOGS_REPO=TotallyKyle/red-10-logs
# ENV_LABEL=local
