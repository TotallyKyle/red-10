{
  "name": "@red10/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ab": "vitest run __tests__/simulator/strategyFixesAB.test.ts __tests__/simulator/defensiveModeAB.test.ts"
  },
  "dependencies": {
    "@red10/shared": "*",
    "express": "^5.1.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "tsx": "^4.19.4",
    "vitest": "^3.1.1"
  }
}
